<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/controlPanel"
    android:layout_width="90dp"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_card"
    android:paddingHorizontal="4dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Заголовок "Управление" -->
    <TextView
        android:id="@+id/controlTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Управление"
        android:textSize="12sp"
        android:textColor="@color/text"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Контейнер для кнопок с прокруткой -->
    <ScrollView
        android:id="@+id/controlScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:scrollbarSize="4dp"
        android:scrollbarThumbVertical="@color/primary"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/controlButtonsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</LinearLayout>